{
  "name": "@mikusnuz/meta-ads-mcp",
  "version": "1.2.0",
  "mcpName": "io.github.mikusnuz/meta-ads",
  "description": "MCP server for Meta Marketing API v25.0 — 123 tools for Facebook & Instagram ad campaign management",
  "type": "module",
  "bin": {
    "meta-ads-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "meta",
    "facebook",
    "instagram",
    "ads",
    "marketing",
    "advertising",
    "campaign"
  ],
  "license": "MIT",
  "author": "mikusnuz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikusnuz/meta-ads-mcp.git"
  },
  "homepage": "https://github.com/mikusnuz/meta-ads-mcp#readme",
  "bugs": {
    "url": "https://github.com/mikusnuz/meta-ads-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
